{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "autobi",
  "version": "0.1.0",
  "identifier": "com.autobi.desktop",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 600,
        "height": 400,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": false,
        "visible": true,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true
      },
      {
        "label": "main",
        "url": "index.html",
        "title": "AUTO BI",
        "visible": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
